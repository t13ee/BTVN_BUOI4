@model BTVN4.Models.TodoItem

<style>
    .purple-header { background-color: #c499cc; color: red; padding: 10px; text-align: center; font-weight: bold; border: 1px solid #000; margin-bottom: 10px; }
    .delete-container { max-width: 600px; margin: 0 auto; text-align: center; }
</style>

<div class="purple-header">BÀI TẬP VẬN DỤNG 2</div>

<div class="delete-container mt-5">
    <h2 class="text-danger">Bạn có chắc chắn muốn xoá công việc này?</h2>
    <div class="card mt-4">
        <div class="card-body">
            <p><strong>Mã:</strong> @Model.Id</p>
            <p><strong>Tên công việc:</strong> @Model.Name</p>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-4">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger btn-lg">Xoá ngay</button>
        <div class="mt-3">
            <a asp-action="Index">Huỷ bỏ và quay lại</a>
        </div>
    </form>
</div>